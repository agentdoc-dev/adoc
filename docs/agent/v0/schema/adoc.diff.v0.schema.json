{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adoc://agent/v0/schema/adoc.diff.v0.schema.json",
  "title": "AgentDoc Object Diff",
  "description": "Mechanical Knowledge-Object-scoped diff between two snapshots of an AgentDoc project. Emitted by `adoc diff` and (V3.6) the `adoc_diff` MCP tool. See V3-DESIGN.md and ADR-0018.",
  "type": "object",
  "required": ["schema_version", "created", "deleted", "changed", "diagnostics"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "adoc.diff.v0" },
    "created": {
      "description": "Knowledge Objects only present on the head side, in Object-ID sort order.",
      "type": "array",
      "items": { "$ref": "#/$defs/knowledgeObjectRecord" }
    },
    "deleted": {
      "description": "Knowledge Objects only present on the base side, in Object-ID sort order.",
      "type": "array",
      "items": { "$ref": "#/$defs/knowledgeObjectRecord" }
    },
    "changed": {
      "description": "Knowledge Objects present on both sides whose `content_hash` differs, in Object-ID sort order.",
      "type": "array",
      "items": { "$ref": "#/$defs/changedEntry" }
    },
    "diagnostics": {
      "description": "Compile diagnostics surfaced during either snapshot's compile.",
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "$defs": {
    "knowledgeObjectRecord": {
      "type": "object",
      "required": ["id", "kind", "content_hash", "body", "page_id", "source_span", "fields", "relations"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]+$"
        },
        "status": { "type": "string" },
        "body": { "type": "string" },
        "page_id": { "type": "string" },
        "source_span": {
          "type": "object",
          "required": ["path", "line", "column"],
          "properties": {
            "path": { "type": "string" },
            "line": { "type": "integer", "minimum": 1 },
            "column": { "type": "integer", "minimum": 1 }
          }
        },
        "fields": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "relations": {
          "type": "object",
          "required": ["depends_on", "supersedes", "related_to"],
          "properties": {
            "depends_on": { "type": "array", "items": { "type": "string" } },
            "supersedes": { "type": "array", "items": { "type": "string" } },
            "related_to": { "type": "array", "items": { "type": "string" } }
          }
        },
        "impacts": {
          "description": "V3.3 opt-in source-path impact list. Repo-relative file paths, sorted and deduplicated. Omitted entirely when the object has no impacts. Tolerant readers must accept this field on `claim` and `decision` nodes.",
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "changedEntry": {
      "type": "object",
      "required": ["id", "base", "head"],
      "properties": {
        "id": { "type": "string" },
        "base": { "$ref": "#/$defs/knowledgeObjectRecord" },
        "head": { "$ref": "#/$defs/knowledgeObjectRecord" },
        "field_changes": {
          "type": "array",
          "description": "V3.2 typed projection over the base/head pair. Optional and omitted entirely when the projection produces no entries V3.2 expresses (e.g. value-only changes to evidence keys, or differences only in fields outside the V3.2 vocabulary). Tolerant readers must ignore unknown `type` values to stay forward-compatible with V3.3+ additions.",
          "items": { "$ref": "#/$defs/fieldChange" }
        }
      },
      "additionalProperties": true
    },
    "fieldChange": {
      "$comment": "Sealed-but-extensible discriminated union; new V3.3+ variants (e.g. impacts_added, impacts_removed) extend the `type` set without bumping the envelope to v1.",
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "before", "after"],
          "properties": {
            "type": { "const": "body" },
            "before": { "type": "string" },
            "after": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "before", "after"],
          "properties": {
            "type": { "const": "status" },
            "before": { "type": ["string", "null"] },
            "after": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "before", "after"],
          "properties": {
            "type": { "const": "owner" },
            "before": { "type": ["string", "null"] },
            "after": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "before", "after"],
          "properties": {
            "type": { "const": "verified_at" },
            "before": { "type": ["string", "null"] },
            "after": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "field", "value"],
          "properties": {
            "type": { "const": "evidence_added" },
            "field": { "type": "string", "enum": ["source", "test", "reviewed_by"] },
            "value": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "field", "value"],
          "properties": {
            "type": { "const": "evidence_removed" },
            "field": { "type": "string", "enum": ["source", "test", "reviewed_by"] },
            "value": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "kind", "target"],
          "properties": {
            "type": { "const": "relation_added" },
            "kind": { "type": "string", "enum": ["depends_on", "supersedes", "related_to"] },
            "target": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "kind", "target"],
          "properties": {
            "type": { "const": "relation_removed" },
            "kind": { "type": "string", "enum": ["depends_on", "supersedes", "related_to"] },
            "target": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "path"],
          "properties": {
            "type": { "const": "impacts_added" },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "path"],
          "properties": {
            "type": { "const": "impacts_removed" },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
