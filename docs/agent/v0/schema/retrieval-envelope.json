{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adoc://agent/v0/schema/retrieval-envelope.json",
  "title": "AgentDoc Retrieval Envelope",
  "type": "object",
  "required": ["schema_version", "records", "diagnostics"],
  "properties": {
    "schema_version": { "const": "adoc.retrieval.v1" },
    "records": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "title": "Knowledge Object record",
            "type": "object",
            "required": ["record_type", "id", "kind", "content_hash", "body", "source", "relations"],
            "properties": {
              "record_type": { "const": "knowledge_object" },
              "id": { "type": "string" },
              "kind": { "type": "string" },
              "content_hash": { "type": "string", "pattern": "^sha256:" },
              "status": { "type": ["string", "null"] },
              "severity": { "type": "string" },
              "trust": { "type": "string" },
              "owner": { "type": "string" },
              "verified_at": { "type": "string" },
              "body": { "type": "string" },
              "source": { "type": "object" },
              "evidence": { "type": "object", "additionalProperties": { "type": "string" } },
              "fields": { "type": "object", "additionalProperties": { "type": "string" } },
              "relations": { "type": "object" },
              "match": { "type": "object" },
              "effective_status": { "type": "string" },
              "effective_reason": { "type": "string" },
              "evidence_quality": { "type": "string" },
              "resolved_questions": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          },
          {
            "title": "Prose record (ADR-0040: orientation context, not citable knowledge)",
            "type": "object",
            "required": ["record_type", "id", "page_id", "block_kind", "text", "source"],
            "properties": {
              "record_type": { "const": "prose" },
              "id": { "type": "string", "pattern": "^.+#block-[0-9]+$" },
              "page_id": { "type": "string" },
              "block_kind": { "enum": ["heading", "paragraph", "list", "code_block"] },
              "text": { "type": "string" },
              "heading_context": { "type": "string" },
              "source": { "type": "object" },
              "match": { "type": "object" }
            },
            "additionalProperties": false
          }
        ]
      }
    },
    "diagnostics": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": false
}
